# ── Backend URL ────────────────────────────────────────────────────────────
# En local : http://localhost:4000
# En prod  : https://votre-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── Google Places (avis) ───────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJR2xafuDr9EcRRioXLswDybg
# Restreindre la clé au domaine de Laetitia dans GCP (HTTP referrers)
NEXT_PUBLIC_GOOGLE_PLACES_KEY=your_places_api_key_here

# ── Google Calendar API ─────────────────────────────────────────────────────
# Créer une clé API dans Google Cloud Console (APIs & Services → Credentials)
# Activer l'API "Google Calendar API"
NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=your_api_key_here
NEXT_PUBLIC_GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com (3000 emails/mois gratuits)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email de la sophrologue (pour les notifications de RDV)
SOPHRO_EMAIL=sophrocoachinglaetitia@gmail.com
