# ── Port ───────────────────────────────────────────────────────────────────
PORT=4000

# ── Google Calendar (Service Account) ──────────────────────────────────────
# 1. Aller sur https://console.cloud.google.com
# 2. Créer un projet → activer "Google Calendar API"
# 3. IAM & Admin → Comptes de service → Créer un compte
# 4. Télécharger la clé JSON → copier les valeurs ici
# 5. Dans Google Agenda : Paramètres du calendrier → Partager avec des personnes
#    → ajouter l'email du compte de service avec droits "Apporter des modifications aux événements"

GOOGLE_SERVICE_ACCOUNT_EMAIL=mon-compte@mon-projet.iam.gserviceaccount.com
# Copier la clé privée EN ENTIER depuis le JSON (avec les \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=sophrocoachinglaetitia@gmail.com

# Durée d'un créneau en minutes (60 = 1h)
SLOT_DURATION_MINUTES=60

# Horaires de disponibilité (format 24h)
AVAILABILITY_START=09:00
AVAILABILITY_END=19:00
# Jours de la semaine (0=dim, 1=lun, ..., 6=sam)
AVAILABILITY_DAYS=1,2,3,4,5

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com (3000 emails/mois gratuits)
# Vérifier un domaine ou utiliser onboarding@resend.dev pour les tests
RESEND_API_KEY=re_xxxxxxxxxxxxx
FROM_EMAIL=noreply@votre-domaine.fr

# Email de la sophrologue
SOPHRO_EMAIL=sophrocoachinglaetitia@gmail.com
SOPHRO_NAME=Laetitia Chastel

# ── Frontend URL (CORS) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
